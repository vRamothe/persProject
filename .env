# Copiez ce fichier en .env et adaptez les valeurs
# Ne committez JAMAIS le fichier .env dans git

POSTGRES_USER=sciencelycee
POSTGRES_PASSWORD=sciencelycee_secret_changez_moi
POSTGRES_DB=sciencelycee

# Générez une clé secrète forte :
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=0000

DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Compte administrateur créé au premier démarrage
FIRST_ADMIN_EMAIL=admin@sciencelycee.fr
FIRST_ADMIN_PASSWORD=1234
FIRST_ADMIN_PRENOM=Administrateur
FIRST_ADMIN_NOM=Principal

# Email (Brevo SMTP — utilisé en production)
DEFAULT_FROM_EMAIL=mr.hijohojo@gmail.com
GITHUB_REPO=vRamothe/persProject

# ─── Stripe (remplacez par vos vraies clés depuis https://dashboard.stripe.com/apikeys) ───
# Les valeurs à obtenir depuis le Stripe Dashboard :
# sk_test_... et pk_test_... → onglet API keys (mode test)
# whsec_... → onglet Webhooks après avoir créé un endpoint pointant vers https://ton-domaine/stripe-webhook/
# price_... → créer 2 Products/Prices (recurring) : un mensuel à 19€, un annuel à 119€

STRIPE_SECRET_KEY=sk_test_REMPLACEZ_PAR_VOTRE_CLE_SECRETE_STRIPE
STRIPE_PUBLISHABLE_KEY=pk_test_REMPLACEZ_PAR_VOTRE_CLE_PUBLIQUE_STRIPE
STRIPE_WEBHOOK_SECRET=whsec_REMPLACEZ_PAR_VOTRE_SECRET_WEBHOOK_STRIPE
STRIPE_PRICE_MONTHLY=price_REMPLACEZ_PAR_ID_PRIX_MENSUEL_19EUR
STRIPE_PRICE_ANNUAL=price_REMPLACEZ_PAR_ID_PRIX_ANNUEL_119EUR